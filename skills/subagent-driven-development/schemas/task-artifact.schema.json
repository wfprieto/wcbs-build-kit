{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wfprieto/wcbs-build-kit/skills/subagent-driven-development/schemas/task-artifact.schema.json",
  "title": "WCBS Task Artifact",
  "description": "Durable record of one delegated task. Canonical contract: skills/subagent-driven-development/SKILL.md",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id","task_id","title","producer_role","created_utc",
    "task_base_sha","apivr_tier","files_editable","files_forbidden",
    "acceptance_criteria","repair_budget","status"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "producer_role": { "enum": ["controller","implementer","task_reviewer","fix_agent","final_reviewer"] },
    "created_utc": { "type": "string", "format": "date-time" },
    "apivr_tier": { "enum": ["Rapid","Standard","Comprehensive","Forensic"] },
    "task_base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$", "description": "Captured BEFORE dispatch. Shortcut refs such as HEAD~1 are prohibited." },
    "task_head_sha": { "type": ["string","null"], "pattern": "^[0-9a-f]{40}$" },
    "brief_revision": { "type": "integer", "minimum": 1, "description": "A dispatched brief is immutable; a correction increments this." },
    "revision_reason": { "type": ["string","null"] },
    "files_editable": { "type": "array", "items": { "type": "string" } },
    "files_forbidden": { "type": "array", "items": { "type": "string" } },
    "canonical_sources": { "type": "array", "items": { "type": "string" } },
    "test_first_requirement": { "type": "string" },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "preserved_behavior": { "type": "array", "items": { "type": "string" } },
    "global_constraints_verbatim": { "type": "string", "description": "Copied verbatim. Summarizing a binding constraint changes its meaning and is prohibited." },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "repair_budget": { "type": "integer", "minimum": 1, "default": 3 },
    "required_artifacts": { "type": "array", "items": { "type": "string" } },
    "reviewer_capability": { "enum": ["standard","advanced","strongest_available"] },
    "status": { "enum": ["PENDING","DISPATCHED","DONE","DONE_WITH_CONCERNS","NEEDS_CONTEXT","BLOCKED","REVIEWED","COMPLETE"] },
    "artifact_paths": { "type": "object", "additionalProperties": { "type": "string" } }
  }
}
